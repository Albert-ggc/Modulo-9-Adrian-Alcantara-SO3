============================================================
PRACTICA 5 - PLAYBOOKS
============================================================
🔹 Playbook Windows (notepad.yml)

nano notepad.yml

Contenido:

name: Instalar Notepad++ en Windows
hosts: win
tasks:
name: Instalar Notepad++
win_chocolatey:
name: notepadplusplus
state: present
🔹 Instalar Chocolatey (REQUERIDO)

Set-ExecutionPolicy Bypass -Scope Process -Force
[System.Net.ServicePointManager]::SecurityProtocol = [System.Net.ServicePointManager]::SecurityProtocol -bor 3072
iex ((New-Object System.Net.WebClient).DownloadString('https://chocolatey.org/install.ps1
'))

🔹 Ejecutar

ansible-playbook notepad.yml

🔹 Playbook Linux (nginx.yml)

nano nginx.yml

Contenido:

name: Instalar NGINX en Linux
hosts: linux
become: yes
tasks:
name: Instalar nginx
apt:
name: nginx
state: present
update_cache: yes
name: Iniciar servicio nginx
service:
name: nginx
state: started
enabled: yes
🔹 Ejecutar

ansible-playbook nginx.yml -K

🔹 Verificación final

ansible all -m ping
curl http://IP_LINUX

